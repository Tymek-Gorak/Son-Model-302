[sub_resource type="GDScript" id="GDScript_msqxa"]
script/source = "extends CanvasLayer

@onready var garder_remaining_label: RichTextLabel = %GarderRemainingLabel

func _ready() -> void:
	get_child(0).hide()
	WeedManager.win.connect(_on_win)
	
	
func _on_win():
	%AudioStreamPlayer.play()
	get_child(0).show()
	var remaining_plants := get_tree().get_node_count_in_group(\"flower\")
	garder_remaining_label.text = \"Garden Remaining: {percent}%\".format({\"percent\": floor((float(remaining_plants)/ WeedManager.starting_plants)*100)})
	
"

